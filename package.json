{
  "name": "gsssupportticketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:https": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev --experimental-https --hostname localhost --port 3000",
    "dev:https:cert": "next dev --experimental-https --experimental-https-key ./certs/localhost-key.pem --experimental-https-cert ./certs/localhost.pem --hostname localhost --port 3000",
    "build": "npx prisma generate && next build",
    "build:out": "cross-env NEXT_DIST_DIR=out npm run build",
    "build:export": "cross-env NEXT_OUTPUT_MODE=export npm run build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "confbox": "^0.2.4",
    "csv-parse": "^6.2.1",
    "googleapis": "^171.4.0",
    "imap-simple": "^5.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "mailparser": "^3.9.6",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "otpauth": "^9.5.0",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "^8.1.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/imap-simple": "^4.2.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
