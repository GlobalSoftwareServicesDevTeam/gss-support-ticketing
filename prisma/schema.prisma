generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  phoneNumber     String?
  company         String?
  companyRegNo    String?
  companyVatNo    String?
  companyAddress  String?   @db.NVarChar(Max)
  position        String?
  role            String    @default("USER") // ADMIN, USER, EDITOR
  emailConfirmed  Boolean   @default(false)
  activationCode  String?
  passwordReset   Boolean   @default(false)
  inviteToken     String?
  inviteExpiresAt DateTime?
  legalAcceptedAt DateTime?
  legalDocVersion String?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  invoiceNinjaClientId String?
  oauthProvider        String?   // google, facebook - null means credentials
  oauthProviderId      String?   // provider's user ID

  // Two-factor authentication
  totpSecret           String?   @db.NVarChar(Max) // encrypted TOTP secret
  totpEnabled          Boolean   @default(false)
  totpBackupCodes      String?   @db.NVarChar(Max) // encrypted JSON array of hashed backup codes

  issues              Issue[]
  messages            Message[]
  assignments         TaskAssignment[]
  projectAssignments  ProjectAssignment[]
  hostingOrders       HostingOrder[]
  codeDownloads       CodeDownloadLog[]
  paymentArrangements PaymentArrangement[]
  trustedDevices      TrustedDevice[]

  @@map("users")
}

model Customer {
  id                   String   @id @default(uuid())
  company              String
  phoneNumber          String?
  contactPerson        String
  emailAddress         String   @unique
  address              String?  @db.NVarChar(Max)
  vatNumber            String?
  regNumber            String?
  invoiceNinjaClientId String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  issues   Issue[]
  contacts Contact[]
  repos    CustomerRepo[]
  vault    SecureNote[]
  quotes   Quote[]

  @@map("customers")
}

model Contact {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  position    String?
  isPrimary   Boolean   @default(false)
  inviteToken String?   @unique
  inviteExpiresAt DateTime?
  invitedAt   DateTime?
  inviteAccepted Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Portal access permissions — primary contacts get all by default
  canViewTickets     Boolean @default(true)
  canViewProjects    Boolean @default(true)
  canViewBilling     Boolean @default(true)  // invoices, payments, arrangements
  canViewHosting     Boolean @default(true)  // hosting orders, domains, DNS
  canViewDocuments   Boolean @default(true)
  canViewCode        Boolean @default(true)  // code history & downloads
  canViewNotifications Boolean @default(true)
  canManageContacts  Boolean @default(false) // only primary contacts

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId      String?   // linked User account if they accepted the invite
  notificationPreferences ContactNotificationPref[]

  @@map("contacts")
}

model ContactNotificationPref {
  id         String  @id @default(uuid())
  channel    String  // EMAIL, SMS, PORTAL
  category   String  // TICKETS, INVOICES, PAYMENTS, PROJECTS, HOSTING, MAINTENANCE, MARKETING, GENERAL
  enabled    Boolean @default(true)

  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([contactId, channel, category])
  @@map("contact_notification_prefs")
}

model UserNotificationPref {
  id         String  @id @default(uuid())
  channel    String  // EMAIL, SMS, PORTAL
  category   String  // TICKETS, INVOICES, PAYMENTS, PROJECTS, HOSTING, MAINTENANCE, MARKETING, GENERAL
  enabled    Boolean @default(true)

  userId     String
  @@unique([userId, channel, category])
  @@map("user_notification_prefs")
}

model Project {
  id                    String    @id @default(uuid())
  projectName           String
  dateCreated           DateTime  @default(now())
  proposalDate          DateTime?
  estimatedCompleteDate DateTime?
  onMaintenance         Boolean   @default(false)
  maintAmount           Decimal?
  contract              Bytes?
  dateStarted           DateTime?
  companyId             String?
  githubRepo            String?
  description           String?   @db.NVarChar(Max)
  status                String    @default("ACTIVE") // ACTIVE, ON_HOLD, COMPLETED, ARCHIVED

  issues      Issue[]
  tasks       Task[]
  documents   Document[]
  assignments ProjectAssignment[]
  codeReleases CodeRelease[]
  repos       GitHubRepo[]
  quotes      Quote[]

  @@map("projects")
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, userId])
  @@map("project_assignments")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.NVarChar(Max)
  status      String    @default("TODO") // TODO, IN_PROGRESS, IN_REVIEW, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  issueId     String?
  issue       Issue?    @relation(fields: [issueId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  assignments TaskAssignment[]

  @@map("tasks")
}

model TaskAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Document {
  id         String   @id @default(uuid())
  name       String
  fileName   String
  fileExt    String
  fileBase64 String   @db.NVarChar(Max)
  fileSize   Int      @default(0)
  category   String   // LEGAL, PROJECT, RESOURCE, CODE, INVOICE, QUOTE, STATEMENT, CREDIT_NOTE, PAYMENT_NOTE, OTHER
  notes      String?  @db.NVarChar(Max)
  uploadedAt DateTime @default(now())

  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  uploadedBy String?

  @@map("documents")
}

model Issue {
  id           String   @id @default(uuid())
  subject      String
  initialNotes String?  @db.NVarChar(Max)
  status       String   @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  kind         String?
  projectName  String?
  company      String?
  emailThreadId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  messages     Message[]
  fileUploads  FileUpload[]
  tasks        Task[]

  @@map("issues")
}

model Message {
  id          String   @id @default(uuid())
  content     String   @db.NVarChar(Max)
  dateCreated DateTime @default(now())
  isFromEmail Boolean  @default(false)

  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  issueId String
  issue   Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("messages")
}

model FileUpload {
  id         String   @id @default(uuid())
  fileName   String
  fileExt    String
  fileBase64 String   @db.NVarChar(Max)
  dateAdded  DateTime @default(now())
  publicDoc  Boolean  @default(false)

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("file_uploads")
}

model MailSetting {
  id        String   @id @default(uuid())
  host      String
  port      Int
  ssl       Boolean  @default(true)
  fromEmail String
  password  String
  subject   String?
  createdAt DateTime @default(now())

  @@map("mail_settings")
}

model Quote {
  id              String    @id @default(uuid())
  quoteNo         String?
  title           String?
  description     String?   @db.NVarChar(Max)
  lineItems       String?   @db.NVarChar(Max) // JSON: [{description, qty, unitPrice, amount}]
  amount          Decimal?
  taxRate         Decimal?  @default(15)
  taxAmount       Decimal?
  totalAmount     Decimal?
  paid            Boolean   @default(false)
  amountPaid      Decimal?
  dueDate         DateTime?
  validUntil      DateTime?
  invoiceNo       String?
  quoteStatus     String?   @default("DRAFT") // DRAFT, SENT, VIEWED, ACCEPTED, DECLINED, EXPIRED, CONVERTED
  notes           String?   @db.NVarChar(Max)
  declineReason   String?   @db.NVarChar(Max)

  // Client info
  clientName      String?
  clientEmail     String?
  clientCompany   String?

  // Signature
  clientSignature String?   @db.NVarChar(Max) // base64 PNG
  clientSignedAt  DateTime?
  clientSignedName String?
  clientIp        String?

  // Token for public access
  token           String?   @unique @default(uuid())

  // Relations
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  sentAt          DateTime?
  sentBy          String?   // userId who sent
  createdBy       String?   // userId who created
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("quotes")
}

model IncomingEmail {
  id          String   @id @default(uuid())
  messageId   String   @unique
  fromEmail   String
  fromName    String?
  subject     String
  bodyText    String?  @db.NVarChar(Max)
  bodyHtml    String?  @db.NVarChar(Max)
  receivedAt  DateTime @default(now())
  processed   Boolean  @default(false)
  issueId     String?

  @@map("incoming_emails")
}

model Payment {
  id              String   @id @default(uuid())
  gateway         String   // PAYFAST, OZOW, EFT
  gatewayRef      String?  // external payment ID from gateway
  amount          Decimal
  currency        String   @default("ZAR")
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED, CANCELLED, REFUNDED
  description     String?
  invoiceNumber   String?
  customerEmail   String?
  customerName    String?
  metadata        String?  @db.NVarChar(Max) // JSON blob for gateway-specific data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String?
  savedCardId     String?
  savedCard       SavedCard? @relation(fields: [savedCardId], references: [id])

  @@map("payments")
}

model SavedCard {
  id            String   @id @default(uuid())
  userId        String
  gateway       String   @default("PAYFAST") // PAYFAST
  token         String   // PayFast ad-hoc token
  cardBrand     String?  // VISA, MASTERCARD, AMEX, etc.
  last4         String?  // Last 4 digits of card
  expiryMonth   Int?
  expiryYear    Int?
  nickname      String?  // User-defined label
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  payments      Payment[]

  @@unique([userId, token])
  @@map("saved_cards")
}

model EftBankDetail {
  id          String   @id @default(uuid())
  bankName    String
  accountName String
  accountNumber String
  branchCode  String
  accountType String?  // SAVINGS, CHEQUE, CURRENT
  swiftCode   String?
  reference   String?  // e.g. "Use your invoice number"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("eft_bank_details")
}

model FlaggedEmail {
  id          String   @id @default(uuid())
  messageId   String   @unique
  fromEmail   String
  fromName    String?
  subject     String
  bodyText    String?  @db.NVarChar(Max)
  bodyHtml    String?  @db.NVarChar(Max)
  reason      String   // BOUNCE, NOREPLY, BLOCKED_SENDER, SUSPICIOUS
  status      String   @default("PENDING") // PENDING, ASSIGNED, IGNORED
  resolvedBy  String?
  resolvedAt  DateTime?
  assignedToIssueId String?
  receivedAt  DateTime @default(now())

  @@map("flagged_emails")
}

model BlockedSender {
  id         String   @id @default(uuid())
  email      String   @unique
  pattern    String?  // optional regex/glob pattern like *@mailer-daemon.*
  reason     String?
  blockedBy  String?
  createdAt  DateTime @default(now())

  @@map("blocked_senders")
}

model SigningRequest {
  id              String    @id @default(uuid())
  documentId      String
  documentName    String
  status          String    @default("PENDING_SIGNER") // PENDING_SIGNER, PENDING_WITNESS, PENDING_ADMIN, COMPLETED, CANCELLED
  signerName      String
  signerEmail     String
  signerSignature String?   @db.NVarChar(Max) // base64 PNG
  signerSignedAt  DateTime?
  signerToken     String    @unique @default(uuid())
  witnessName     String?
  witnessEmail    String?
  witnessSignature String?  @db.NVarChar(Max) // base64 PNG
  witnessSignedAt DateTime?
  witnessToken    String?   @unique
  adminSignature  String?   @db.NVarChar(Max) // base64 PNG
  adminSignedAt   DateTime?
  adminToken      String?   @unique
  createdBy       String    // userId who initiated
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("signing_requests")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.NVarChar(Max)
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model HostingProduct {
  id          String   @id @default(uuid())
  name        String
  type        String   // HOSTING, SSL, DOMAIN
  description String?  @db.NVarChar(Max)
  monthlyPrice Decimal
  annualPrice  Decimal?
  setupFee    Decimal  @default(0)
  features    String?  @db.NVarChar(Max) // JSON array of feature strings
  pleskPlanName String? // Plesk service plan name for auto-provisioning
  pleskPlanId  Int?     // Plesk service plan ID
  // Plesk plan limits (synced from Plesk)
  diskSpace    String?  // e.g. "10 GB", "unlimited"
  bandwidth    String?  // e.g. "100 GB", "unlimited"
  databases    String?  // e.g. "5", "unlimited"
  emailAccounts String? // e.g. "10", "unlimited"
  emailStorage String?  // e.g. "1 GB per mailbox"
  ftpAccounts  String?  // e.g. "5", "unlimited"
  subdomains   String?  // e.g. "10", "unlimited"
  sslSupport   Boolean  @default(true)
  phpSupport   Boolean  @default(true)
  backups      String?  // e.g. "Daily", "Weekly"
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  orders HostingOrder[]

  @@map("hosting_products")
}

model HostingOrder {
  id              String    @id @default(uuid())
  orderType       String    // HOSTING, DOMAIN_REGISTER, DOMAIN_TRANSFER, DOMAIN_CHECK, SSL, ADDITIONAL_HOSTING, QUOTE_REQUEST
  status          String    @default("PENDING") // PENDING, QUOTED, PROFORMA_SENT, PAID, PROVISIONING, ACTIVE, FAILED, CANCELLED
  domain          String?
  notes           String?   @db.NVarChar(Max)
  amount          Decimal?
  period          Int       @default(1) // months
  pleskSubscriptionId String?
  invoiceNinjaInvoiceId String?
  recurringInvoiceId String?
  provisionedAt   DateTime?
  expiryDate      DateTime? // domain expiry date
  reminderSentAt  DateTime? // last reminder email sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId String?
  product   HostingProduct? @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("hosting_orders")
}

model CodeRelease {
  id          String   @id @default(uuid())
  version     String   // e.g. "1.0.0", "2.3.1"
  notes       String?  @db.NVarChar(Max) // changelog / release notes
  fileName    String
  fileExt     String
  fileBase64  String   @db.NVarChar(Max) // base64 encoded zip/tar
  fileSize    Int      @default(0)
  uploadedBy  String?
  createdAt   DateTime @default(now())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  downloads   CodeDownloadLog[]

  @@map("code_releases")
}

model CodeDownloadLog {
  id            String   @id @default(uuid())
  downloadedAt  DateTime @default(now())
  ipAddress     String?

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  codeReleaseId String
  codeRelease   CodeRelease  @relation(fields: [codeReleaseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("code_download_logs")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, DOWNLOAD, PROVISION, CANCEL, CREDIT, etc.
  entity      String   // USER, ISSUE, PROJECT, DOCUMENT, HOSTING_ORDER, HOSTING_PRODUCT, PAYMENT, etc.
  entityId    String?  // ID of the affected entity
  description String   @db.NVarChar(Max)
  metadata    String?  @db.NVarChar(Max) // JSON blob with additional context
  ipAddress   String?
  userAgent   String?  @db.NVarChar(Max)
  userId      String?  // who performed the action
  userName    String?  // denormalized for display when user is deleted
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model PaymentArrangement {
  id              String   @id @default(uuid())
  invoiceNumber   String   // Invoice Ninja invoice number
  invoiceId       String?  // Invoice Ninja invoice ID
  totalAmount     Decimal  // full outstanding amount
  numberOfMonths  Int      // 1–3 months
  monthlyAmount   Decimal  // totalAmount / numberOfMonths
  reason          String?  @db.NVarChar(Max) // user's reason for arrangement
  status          String   @default("PENDING") // PENDING, APPROVED, ACTIVE, COMPLETED, DEFAULTED, REJECTED, CANCELLED
  adminNotes      String?  @db.NVarChar(Max)
  approvedAt      DateTime?
  approvedBy      String?  // admin user ID
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  installments    PaymentArrangementInstallment[]

  @@index([userId])
  @@index([status])
  @@map("payment_arrangements")
}

model PaymentArrangementInstallment {
  id              String    @id @default(uuid())
  installmentNo   Int       // 1, 2, 3
  amount          Decimal
  dueDate         DateTime
  status          String    @default("PENDING") // PENDING, PAID, OVERDUE, WAIVED
  paidAt          DateTime?
  paymentId       String?   // links to Payment record if paid via platform
  gatewayRef      String?   // external payment reference
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  arrangementId   String
  arrangement     PaymentArrangement @relation(fields: [arrangementId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([arrangementId])
  @@index([dueDate])
  @@map("payment_arrangement_installments")
}

model GitHubRepo {
  id          String   @id @default(uuid())
  owner       String   // GitHub org or user
  name        String   // repo name
  fullName    String   // owner/name
  description String?  @db.NVarChar(Max)
  htmlUrl     String   // https://github.com/owner/name
  isPrivate   Boolean  @default(false)
  language    String?
  createdAt   DateTime @default(now())

  customers CustomerRepo[]

  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([owner, name])
  @@map("github_repos")
}

model CustomerRepo {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())
  assignedBy String?  // admin userId

  customerId String
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  repoId     String
  repo       GitHubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customerId, repoId])
  @@map("customer_repos")
}

model SecureNote {
  id          String   @id @default(uuid())
  label       String   // e.g. "cPanel Login", "FTP Credentials"
  category    String   @default("GENERAL") // GENERAL, HOSTING, DATABASE, API, EMAIL, FTP, OTHER
  encValue    String   @db.NVarChar(Max)   // AES-256-GCM encrypted JSON blob
  notes       String?  @db.NVarChar(Max)   // optional unencrypted notes/description
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdBy   String?  // userId who created this

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("secure_notes")
}

model BulkEmailCampaign {
  id            String    @id @default(uuid())
  name          String                            // campaign name/label
  subject       String                            // email subject line
  contentHtml   String?   @db.NVarChar(Max)       // HTML body
  contentText   String?   @db.NVarChar(Max)       // plain text body
  format        String    @default("html")        // "html" | "text"
  status        String    @default("DRAFT")       // DRAFT, SENDING, SENT, FAILED
  recipientFilter String? @db.NVarChar(Max)       // JSON: {type: "all"|"customers"|"contacts"|"custom", customerIds?: [], contactIds?: []}
  totalRecipients Int     @default(0)
  sentCount     Int       @default(0)
  failedCount   Int       @default(0)
  sentAt        DateTime?
  completedAt   DateTime?
  createdBy     String
  createdByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recipients    BulkEmailRecipient[]

  @@index([status])
  @@index([createdAt])
  @@map("bulk_email_campaigns")
}

model BulkEmailRecipient {
  id          String    @id @default(uuid())
  campaignId  String
  campaign    BulkEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  email       String
  name        String?
  company     String?
  status      String    @default("PENDING")       // PENDING, SENT, FAILED
  error       String?   @db.NVarChar(Max)
  sentAt      DateTime?
  customerId  String?
  contactId   String?

  @@index([campaignId])
  @@index([status])
  @@map("bulk_email_recipients")
}

model TrustedDevice {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tokenHash   String   // SHA-256 hash of the trust token
  deviceName  String?  // User-Agent or device description
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("trusted_devices")
}
