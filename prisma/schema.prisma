generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  username             String               @unique
  passwordHash         String
  firstName            String
  lastName             String
  phoneNumber          String?
  company              String?
  companyRegNo         String?
  companyVatNo         String?
  companyAddress       String?              @db.NVarChar(Max)
  position             String?
  role                 String               @default("USER")
  emailConfirmed       Boolean              @default(false)
  activationCode       String?
  passwordReset        Boolean              @default(false)
  inviteToken          String?
  inviteExpiresAt      DateTime?
  legalAcceptedAt      DateTime?
  legalDocVersion      String?
  isDeleted            Boolean              @default(false)
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  invoiceNinjaClientId String?
  oauthProvider        String?
  oauthProviderId      String?
  totpSecret           String?              @db.NVarChar(Max)
  totpEnabled          Boolean              @default(false)
  totpBackupCodes      String?              @db.NVarChar(Max)
  codeDownloads        CodeDownloadLog[]
  hostingOrders        HostingOrder[]
  issues               Issue[]
  messages             Message[]
  paymentArrangements  PaymentArrangement[]
  projectAssignments   ProjectAssignment[]
  assignments          TaskAssignment[]
  trustedDevices       TrustedDevice[]

  @@map("users")
}

model Customer {
  id                   String         @id @default(uuid())
  company              String
  phoneNumber          String?
  contactPerson        String
  emailAddress         String         @unique
  address              String?        @db.NVarChar(Max)
  vatNumber            String?
  regNumber            String?
  invoiceNinjaClientId String?
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @default(now()) @updatedAt
  contacts             Contact[]
  repos                CustomerRepo[]
  hostingOrders        HostingOrder[]
  issues               Issue[]
  apps                 MobileApp[]
  projectIdeas         ProjectIdea[]
  projects             Project[]
  quotes               Quote[]
  referrals            Referral[]
  vault                SecureNote[]

  @@map("customers")
}

model Contact {
  id                      String                    @id @default(uuid())
  firstName               String
  lastName                String
  email                   String
  phone                   String?
  position                String?
  isPrimary               Boolean                   @default(false)
  inviteToken             String?
  inviteExpiresAt         DateTime?
  invitedAt               DateTime?
  inviteAccepted          Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  canViewTickets          Boolean                   @default(true)
  canViewProjects         Boolean                   @default(true)
  canViewBilling          Boolean                   @default(true)
  canViewHosting          Boolean                   @default(true)
  canViewDocuments        Boolean                   @default(true)
  canViewCode             Boolean                   @default(true)
  canViewNotifications    Boolean                   @default(true)
  canManageContacts       Boolean                   @default(false)
  customerId              String
  userId                  String?
  notificationPreferences ContactNotificationPref[]
  customer                Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("contacts")
}

model ContactNotificationPref {
  id        String  @id @default(uuid())
  channel   String
  category  String
  enabled   Boolean @default(true)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([contactId, channel, category])
  @@map("contact_notification_prefs")
}

model UserNotificationPref {
  id       String  @id @default(uuid())
  channel  String
  category String
  enabled  Boolean @default(true)
  userId   String

  @@unique([userId, channel, category])
  @@map("user_notification_prefs")
}

model Project {
  id                    String              @id @default(uuid())
  projectName           String
  dateCreated           DateTime            @default(now())
  proposalDate          DateTime?
  estimatedCompleteDate DateTime?
  onMaintenance         Boolean             @default(false)
  maintAmount           Decimal?
  contract              Bytes?
  dateStarted           DateTime?
  companyId             String?
  githubRepo            String?
  description           String?             @db.NVarChar(Max)
  status                String              @default("ACTIVE")
  customerId            String?
  codeReleases          CodeRelease[]
  documents             Document[]
  repos                 GitHubRepo[]
  hostingOrders         HostingOrder[]
  issues                Issue[]
  assignments           ProjectAssignment[]
  customer              Customer?           @relation(fields: [customerId], references: [id])
  quotes                Quote[]
  subProjects           SubProject[]
  tasks                 Task[]

  @@map("projects")
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())
  projectId  String
  userId     String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([projectId, userId])
  @@map("project_assignments")
}

model Task {
  id                String           @id @default(uuid())
  title             String
  description       String?          @db.NVarChar(Max)
  status            String           @default("TODO")
  priority          String           @default("MEDIUM")
  dueDate           DateTime?
  order             Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  projectId         String
  issueId           String?
  stageId           String?
  estimatedDuration Int?
  startTime         String?
  startDate         DateTime?
  assignments       TaskAssignment[]
  issue             Issue?           @relation(fields: [issueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stage             SubProjectStage? @relation(fields: [stageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("tasks")
}

model SubProject {
  id            String            @id @default(uuid())
  name          String
  description   String?           @db.NVarChar(Max)
  status        String            @default("ACTIVE")
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  projectId     String
  repos         GitHubRepo[]
  hostingOrders HostingOrder[]
  stages        SubProjectStage[]
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("sub_projects")
}

model SubProjectStage {
  id           String     @id @default(uuid())
  name         String
  description  String?    @db.NVarChar(Max)
  status       String     @default("NOT_STARTED")
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  subProjectId String
  subProject   SubProject @relation(fields: [subProjectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks        Task[]

  @@map("sub_project_stages")
}

model TaskAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())
  taskId     String
  userId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Document {
  id         String   @id @default(uuid())
  name       String
  fileName   String
  fileExt    String
  fileBase64 String   @db.NVarChar(Max)
  fileSize   Int      @default(0)
  category   String
  notes      String?  @db.NVarChar(Max)
  uploadedAt DateTime @default(now())
  projectId  String?
  uploadedBy String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("documents")
}

model Issue {
  id            String       @id @default(uuid())
  subject       String
  initialNotes  String?      @db.NVarChar(Max)
  status        String       @default("OPEN")
  priority      String       @default("MEDIUM")
  kind          String?
  projectName   String?
  company       String?
  emailThreadId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String?
  customerId    String?
  projectId     String?
  fileUploads   FileUpload[]
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User?        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages      Message[]
  tasks         Task[]

  @@map("issues")
}

model Message {
  id          String   @id @default(uuid())
  content     String   @db.NVarChar(Max)
  dateCreated DateTime @default(now())
  isFromEmail Boolean  @default(false)
  userId      String?
  issueId     String
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("messages")
}

model FileUpload {
  id         String   @id @default(uuid())
  fileName   String
  fileExt    String
  fileBase64 String   @db.NVarChar(Max)
  dateAdded  DateTime @default(now())
  publicDoc  Boolean  @default(false)
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("file_uploads")
}

model MailSetting {
  id        String   @id @default(uuid())
  host      String
  port      Int
  ssl       Boolean  @default(true)
  fromEmail String
  password  String
  subject   String?
  createdAt DateTime @default(now())

  @@map("mail_settings")
}

model Quote {
  id               String    @id @default(uuid())
  quoteNo          String?
  title            String?
  description      String?   @db.NVarChar(Max)
  lineItems        String?   @db.NVarChar(Max)
  amount           Decimal?
  taxRate          Decimal?  @default(15)
  taxAmount        Decimal?
  totalAmount      Decimal?
  paid             Boolean   @default(false)
  amountPaid       Decimal?
  dueDate          DateTime?
  validUntil       DateTime?
  invoiceNo        String?
  quoteStatus      String?   @default("DRAFT")
  notes            String?   @db.NVarChar(Max)
  declineReason    String?   @db.NVarChar(Max)
  clientName       String?
  clientEmail      String?
  clientCompany    String?
  clientSignature  String?   @db.NVarChar(Max)
  clientSignedAt   DateTime?
  clientSignedName String?
  clientIp         String?
  token            String?   @unique @default(uuid())
  customerId       String?
  projectId        String?
  sentAt           DateTime?
  sentBy           String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("quotes")
}

model IncomingEmail {
  id         String   @id @default(uuid())
  messageId  String   @unique
  fromEmail  String
  fromName   String?
  subject    String
  bodyText   String?  @db.NVarChar(Max)
  bodyHtml   String?  @db.NVarChar(Max)
  receivedAt DateTime @default(now())
  processed  Boolean  @default(false)
  issueId    String?

  @@map("incoming_emails")
}

model Payment {
  id            String     @id @default(uuid())
  gateway       String
  gatewayRef    String?
  amount        Decimal
  currency      String     @default("ZAR")
  status        String     @default("PENDING")
  description   String?
  invoiceNumber String?
  customerEmail String?
  customerName  String?
  metadata      String?    @db.NVarChar(Max)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userId        String?
  savedCardId   String?
  savedCard     SavedCard? @relation(fields: [savedCardId], references: [id])

  @@map("payments")
}

model SavedCard {
  id          String    @id @default(uuid())
  userId      String
  gateway     String    @default("PAYFAST")
  token       String
  cardBrand   String?
  last4       String?
  expiryMonth Int?
  expiryYear  Int?
  nickname    String?
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[]

  @@unique([userId, token])
  @@map("saved_cards")
}

model EftBankDetail {
  id            String   @id @default(uuid())
  bankName      String
  accountName   String
  accountNumber String
  branchCode    String
  accountType   String?
  swiftCode     String?
  reference     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("eft_bank_details")
}

model FlaggedEmail {
  id                String    @id @default(uuid())
  messageId         String    @unique
  fromEmail         String
  fromName          String?
  subject           String
  bodyText          String?   @db.NVarChar(Max)
  bodyHtml          String?   @db.NVarChar(Max)
  reason            String
  status            String    @default("PENDING")
  resolvedBy        String?
  resolvedAt        DateTime?
  assignedToIssueId String?
  receivedAt        DateTime  @default(now())

  @@map("flagged_emails")
}

model BlockedSender {
  id        String   @id @default(uuid())
  email     String   @unique
  pattern   String?
  reason    String?
  blockedBy String?
  createdAt DateTime @default(now())

  @@map("blocked_senders")
}

model SigningRequest {
  id               String    @id @default(uuid())
  documentId       String
  documentName     String
  status           String    @default("PENDING_SIGNER")
  signerName       String
  signerEmail      String
  signerSignature  String?   @db.NVarChar(Max)
  signerSignedAt   DateTime?
  signerToken      String    @unique @default(uuid())
  witnessName      String?
  witnessEmail     String?
  witnessSignature String?   @db.NVarChar(Max)
  witnessSignedAt  DateTime?
  witnessToken     String?   @unique
  adminSignature   String?   @db.NVarChar(Max)
  adminSignedAt    DateTime?
  adminToken       String?   @unique
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("signing_requests")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.NVarChar(Max)
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model HostingProduct {
  id            String         @id @default(uuid())
  name          String
  type          String
  description   String?        @db.NVarChar(Max)
  monthlyPrice  Decimal
  annualPrice   Decimal?
  setupFee      Decimal        @default(0)
  features      String?        @db.NVarChar(Max)
  pleskPlanName String?
  pleskPlanId   Int?
  diskSpace     String?
  bandwidth     String?
  databases     String?
  emailAccounts String?
  emailStorage  String?
  ftpAccounts   String?
  subdomains    String?
  sslSupport    Boolean        @default(true)
  phpSupport    Boolean        @default(true)
  backups       String?
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  orders        HostingOrder[]

  @@map("hosting_products")
}

model HostingOrder {
  id                    String          @id @default(uuid())
  orderType             String
  status                String          @default("PENDING")
  domain                String?
  notes                 String?         @db.NVarChar(Max)
  amount                Decimal?
  period                Int             @default(1)
  pleskSubscriptionId   String?
  invoiceNinjaInvoiceId String?
  recurringInvoiceId    String?
  provisionedAt         DateTime?
  expiryDate            DateTime?
  reminderSentAt        DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  userId                String
  productId             String?
  customerId            String?
  projectId             String?
  subProjectId          String?
  customer              Customer?       @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product               HostingProduct? @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project               Project?        @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subProject            SubProject?     @relation(fields: [subProjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                  User            @relation(fields: [userId], references: [id], onUpdate: NoAction)
  sslCertificate        SslCertificate?

  @@map("hosting_orders")
}

model SslCertificate {
  id                String       @id @default(uuid())
  orderId           String       @unique
  digicertOrderId   Int?
  productType       String
  commonName        String
  sans              String?      @db.NVarChar(Max)
  status            String       @default("PENDING")
  csr               String?      @db.NVarChar(Max)
  privateKey        String?      @db.NVarChar(Max)
  certificate       String?      @db.NVarChar(Max)
  intermediateCert  String?      @db.NVarChar(Max)
  rootCert          String?      @db.NVarChar(Max)
  validationType    String?
  validationStatus  String?
  validationDetails String?      @db.NVarChar(Max)
  validFrom         DateTime?
  validTo           DateTime?
  issuedAt          DateTime?
  renewalInvoiceId  String?
  reminderSentAt    DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  order             HostingOrder @relation(fields: [orderId], references: [id], onUpdate: NoAction)

  @@index([digicertOrderId])
  @@index([validTo])
  @@map("ssl_certificates")
}

model CodeRelease {
  id         String            @id @default(uuid())
  version    String
  notes      String?           @db.NVarChar(Max)
  fileName   String
  fileExt    String
  fileBase64 String            @db.NVarChar(Max)
  fileSize   Int               @default(0)
  uploadedBy String?
  createdAt  DateTime          @default(now())
  projectId  String
  downloads  CodeDownloadLog[]
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("code_releases")
}

model CodeDownloadLog {
  id            String      @id @default(uuid())
  downloadedAt  DateTime    @default(now())
  ipAddress     String?
  userId        String
  codeReleaseId String
  codeRelease   CodeRelease @relation(fields: [codeReleaseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user          User        @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@map("code_download_logs")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  description String   @db.NVarChar(Max)
  metadata    String?  @db.NVarChar(Max)
  ipAddress   String?
  userAgent   String?  @db.NVarChar(Max)
  userId      String?
  userName    String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model PaymentArrangement {
  id             String                          @id @default(uuid())
  invoiceNumber  String
  invoiceId      String?
  totalAmount    Decimal
  numberOfMonths Int
  monthlyAmount  Decimal
  reason         String?                         @db.NVarChar(Max)
  status         String                          @default("PENDING")
  adminNotes     String?                         @db.NVarChar(Max)
  approvedAt     DateTime?
  approvedBy     String?
  completedAt    DateTime?
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  userId         String
  installments   PaymentArrangementInstallment[]
  user           User                            @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([userId])
  @@index([status])
  @@map("payment_arrangements")
}

model PaymentArrangementInstallment {
  id            String             @id @default(uuid())
  installmentNo Int
  amount        Decimal
  dueDate       DateTime
  status        String             @default("PENDING")
  paidAt        DateTime?
  paymentId     String?
  gatewayRef    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  arrangementId String
  arrangement   PaymentArrangement @relation(fields: [arrangementId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([arrangementId])
  @@index([dueDate])
  @@map("payment_arrangement_installments")
}

model GitHubAccount {
  id           String       @id @default(uuid())
  label        String
  owner        String       @unique
  patEncrypted String       @db.NVarChar(Max)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  repos        GitHubRepo[]

  @@map("github_accounts")
}

model GitHubRepo {
  id           String         @id @default(uuid())
  owner        String
  name         String
  fullName     String
  description  String?        @db.NVarChar(Max)
  htmlUrl      String
  isPrivate    Boolean        @default(false)
  language     String?
  createdAt    DateTime       @default(now())
  projectId    String?
  subProjectId String?
  accountId    String?
  customers    CustomerRepo[]
  account      GitHubAccount? @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subProject   SubProject?    @relation(fields: [subProjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([owner, name])
  @@map("github_repos")
}

model CustomerRepo {
  id         String     @id @default(uuid())
  assignedAt DateTime   @default(now())
  assignedBy String?
  customerId String
  repoId     String
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  repo       GitHubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customerId, repoId])
  @@map("customer_repos")
}

model SecureNote {
  id         String   @id @default(uuid())
  label      String
  category   String   @default("GENERAL")
  encValue   String   @db.NVarChar(Max)
  notes      String?  @db.NVarChar(Max)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  createdBy  String?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("secure_notes")
}

model BulkEmailCampaign {
  id              String               @id @default(uuid())
  name            String
  subject         String
  contentHtml     String?              @db.NVarChar(Max)
  contentText     String?              @db.NVarChar(Max)
  format          String               @default("html")
  status          String               @default("DRAFT")
  recipientFilter String?              @db.NVarChar(Max)
  totalRecipients Int                  @default(0)
  sentCount       Int                  @default(0)
  failedCount     Int                  @default(0)
  sentAt          DateTime?
  completedAt     DateTime?
  createdBy       String
  createdByName   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  recipients      BulkEmailRecipient[]

  @@index([status])
  @@index([createdAt])
  @@map("bulk_email_campaigns")
}

model BulkEmailRecipient {
  id         String            @id @default(uuid())
  campaignId String
  email      String
  name       String?
  company    String?
  status     String            @default("PENDING")
  error      String?           @db.NVarChar(Max)
  sentAt     DateTime?
  customerId String?
  contactId  String?
  campaign   BulkEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaignId])
  @@index([status])
  @@map("bulk_email_recipients")
}

model TrustedDevice {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  deviceName String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([tokenHash])
  @@map("trusted_devices")
}

model MobileApp {
  id          String              @id @default(uuid())
  name        String
  bundleId    String
  platform    String
  storeUrl    String?             @db.NVarChar(Max)
  packageName String?
  appleId     String?
  iconUrl     String?             @db.NVarChar(Max)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  customerId  String
  builds      AppBuild[]
  stats       AppStoreStatistic[]
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([bundleId, platform])
  @@index([customerId])
  @@map("mobile_apps")
}

model AppStoreStatistic {
  id            String    @id @default(uuid())
  date          DateTime
  downloads     Int       @default(0)
  updates       Int       @default(0)
  activeDevices Int       @default(0)
  revenue       Decimal   @default(0) @db.Decimal(18, 2)
  ratings       Int       @default(0)
  averageRating Decimal?  @db.Decimal(3, 2)
  crashes       Int       @default(0)
  uninstalls    Int       @default(0)
  country       String?
  createdAt     DateTime  @default(now())
  appId         String
  app           MobileApp @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([appId, date, country])
  @@index([appId, date])
  @@map("app_store_statistics")
}

model AppBuild {
  id              String    @id @default(uuid())
  version         String
  buildNumber     String
  status          String    @default("SUBMITTED")
  trackOrChannel  String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  releasedAt      DateTime?
  releaseNotes    String?   @db.NVarChar(Max)
  rejectionReason String?   @db.NVarChar(Max)
  notifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  appId           String
  app             MobileApp @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([appId, status])
  @@index([status])
  @@map("app_builds")
}

model Referral {
  id               String    @id @default(uuid())
  referrerName     String
  referrerEmail    String
  referrerPhone    String?
  refereeName      String
  refereeEmail     String
  refereePhone     String?
  refereeCompany   String?
  service          String?
  notes            String?   @db.NVarChar(Max)
  status           String    @default("PENDING")
  commissionRate   Float     @default(10)
  commissionAmount Float?
  dealValue        Float?
  paidAt           DateTime?
  convertedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id], onUpdate: NoAction)

  @@index([status])
  @@index([referrerEmail])
  @@map("referrals")
}

model ProjectIdea {
  id           String    @id @default(uuid())
  title        String
  description  String    @db.NVarChar(Max)
  category     String    @default("GENERAL")
  priority     String    @default("MEDIUM")
  status       String    @default("NEW")
  budget       Float?
  timeline     String?
  attachments  String?   @db.NVarChar(Max)
  adminNotes   String?   @db.NVarChar(Max)
  submittedBy  String?
  contactEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onUpdate: NoAction)

  @@index([status])
  @@index([category])
  @@map("project_ideas")
}
